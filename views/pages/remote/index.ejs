<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Remote Control | DVLCube</title>

    <!-- Materialize CSS -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/remote.css">
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="nav-wrapper">
            <a href="/" class="brand-logo" style="margin-left: 20px;">
                <i class="material-icons">settings_remote</i>
                Remote Control
            </a>
            <ul id="nav-mobile" class="right hide-on-med-and-down">
                <li><a href="/tools">Tools</a></li>
                <li><a href="/">Home</a></li>
            </ul>
        </div>
    </nav>

    <div class="main-container">
        <!-- No Session View -->
        <div id="no-session" class="center-content">
            <div class="session-card">
                <i class="material-icons large-icon">cast_connected</i>
                <h4>Copilot Remote Control</h4>
                <p class="grey-text">Send prompts to your AI coding session from any device. Create a session, then connect your local agent to start receiving commands.</p>
                
                <div class="action-buttons">
                    <button class="btn-large waves-effect waves-light" onclick="createSession()">
                        <i class="material-icons left">add_circle</i>
                        New Session
                    </button>
                    <div class="input-field inline join-field">
                        <input id="join-session-id" type="text" placeholder="Session ID">
                        <button class="btn waves-effect waves-light" onclick="joinSession()">
                            <i class="material-icons left">login</i>
                            Join
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Active Session View -->
        <div id="active-session" style="display: none;">
            <!-- Session Header -->
            <div class="session-header">
                <div class="session-info">
                    <span class="session-label">Session</span>
                    <code class="session-id" id="session-id-display"></code>
                    <button class="btn-flat btn-small" onclick="copySessionId()" title="Copy session ID">
                        <i class="material-icons">content_copy</i>
                    </button>
                    <span class="connection-status" id="connection-status">
                        <i class="material-icons tiny">circle</i>
                        <span>Connecting...</span>
                    </span>
                </div>
                <div class="session-info-right">
                    <span id="copilot-session-display" class="copilot-session-badge" style="display: none;" title="Copilot CLI Session ID">
                        <i class="material-icons tiny">smart_toy</i>
                        <span id="copilot-session-id-text"></span>
                        <button class="btn-flat btn-small" onclick="copyCopilotSessionId()" title="Copy Copilot session ID">
                            <i class="material-icons">content_copy</i>
                        </button>
                    </span>
                    <div class="session-actions">
                        <button class="btn-flat btn-small tooltipped" onclick="showAgentSetup()" title="Agent setup">
                            <i class="material-icons">terminal</i>
                        </button>
                        <button class="btn-flat btn-small red-text" onclick="disconnectSession()" title="Disconnect">
                            <i class="material-icons">power_settings_new</i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Agent Setup Panel (collapsible) -->
            <div id="agent-setup" class="agent-setup" style="display: none;">
                <h6><i class="material-icons">integration_instructions</i> Agent Setup</h6>
                <p class="grey-text text-darken-1">Run this polling loop on your local machine to pick up commands:</p>
                
                <div class="code-block">
                    <div class="code-header">
                        <span>Node.js Agent (recommended)</span>
                        <button class="btn-flat btn-small" onclick="copyAgentScript()" title="Copy">
                            <i class="material-icons">content_copy</i>
                        </button>
                    </div>
                    <pre id="agent-script"></pre>
                </div>

                <div class="code-block">
                    <div class="code-header">
                        <span>Single poll (curl)</span>
                        <button class="btn-flat btn-small" onclick="copyCurlCommand()" title="Copy">
                            <i class="material-icons">content_copy</i>
                        </button>
                    </div>
                    <pre id="curl-command"></pre>
                </div>

                <p class="grey-text text-darken-1" style="margin-top: 16px;">
                    Or integrate using the API endpoints:
                </p>
                <div class="api-endpoints">
                    <div class="endpoint"><span class="method get">GET</span><code id="poll-url"></code> — Poll for pending commands</div>
                    <div class="endpoint"><span class="method post">POST</span><code id="ack-url"></code> — Acknowledge receipt</div>
                    <div class="endpoint"><span class="method post">POST</span><code id="respond-url"></code> — Send response/output</div>
                </div>
            </div>

            <!-- Command Input -->
            <div class="command-input-area">
                <div class="input-field">
                    <textarea id="command-input" class="materialize-textarea" placeholder="Type a prompt for your Copilot session..." rows="3"></textarea>
                </div>

                <!-- Copilot Options Row -->
                <div class="copilot-options">
                    <div class="option-group">
                        <label class="option-label">Model</label>
                        <select id="model-select" class="browser-default">
                            <option value="">(default)</option>
                            <option value="gpt-4o">gpt-4o</option>
                            <option value="gpt-4.1">gpt-4.1</option>
                            <option value="gpt-4.1-mini">gpt-4.1-mini</option>
                            <option value="gpt-4.1-nano">gpt-4.1-nano</option>
                            <option value="gpt-5">gpt-5</option>
                            <option value="gpt-5-mini">gpt-5-mini</option>
                            <option value="o3">o3</option>
                            <option value="o4-mini">o4-mini</option>
                            <option value="claude-sonnet-4">claude-sonnet-4</option>
                            <option value="claude-opus-4">claude-opus-4</option>
                            <option value="gemini-2.5-pro">gemini-2.5-pro</option>
                        </select>
                    </div>
                    <div class="option-group">
                        <label>
                            <input type="checkbox" id="yolo-checkbox" />
                            <span>YOLO <i class="material-icons tiny" title="Allow all tool permissions (--yolo)">bolt</i></span>
                        </label>
                    </div>
                    <div class="option-group">
                        <label class="option-label">Copilot Session</label>
                        <input type="text" id="copilot-session-input" placeholder="(auto)" class="copilot-session-field">
                    </div>
                </div>

                <div class="command-toolbar">
                    <div class="command-type-selector">
                        <label>
                            <input name="cmd-type" type="radio" value="prompt" checked />
                            <span>Prompt</span>
                        </label>
                        <label>
                            <input name="cmd-type" type="radio" value="terminal" />
                            <span>Terminal</span>
                        </label>
                        <label>
                            <input name="cmd-type" type="radio" value="file" />
                            <span>File Edit</span>
                        </label>
                    </div>
                    <button class="btn waves-effect waves-light" id="send-btn" onclick="sendCommand()">
                        <i class="material-icons right">send</i>
                        Send
                    </button>
                </div>
            </div>

            <!-- Command History -->
            <div class="command-history" id="command-history">
                <h6 class="history-title"><i class="material-icons">history</i> Command Queue</h6>
                <div id="command-list" class="command-list">
                    <div class="empty-state">
                        <i class="material-icons">inbox</i>
                        <p>No commands yet. Type a prompt above to get started.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast template for notifications -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <script src="/js/remote.js"></script>
</body>
</html>
